{
    "name": "bingstats/vstats",
    "description": "Drupal installation profile for self learning.",
    "type": "drupal-custom-profile",
    "repositories": {
        "drupal": {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        "asset": {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    },
    "require": {
        "drupal/adminimal_admin_toolbar": "^1.11",
        "drupal/bootstrap_barrio": "^5.5",
        "drupal/bootstrap_layout_builder": "^2.0",
        "drupal/field_group": "^3.0",
        "drupal/fontawesome": "^2.19",
        "drupal/flood_control": "^2.1",
        "drupal/imce": "^2.4",
        "drupal/layout_builder_blocks": "^1.0",
        "drupal/layout_builder_modal": "^1.1",
        "drupal/layout_builder_restrictions": "^2.10",
        "drupal/link_attributes": "^1.1",
        "drupal/module_filter": "^3.2",
        "drupal/page_load_progress": "^2.0",
        "drupal/pathauto": "^1.8",
        "drupal/reroute_email": "^2.1",
        "drupal/select2": "^1.13",
        "drupal/taxonomy_manager": "^2.0",
        "drupal/xmlsitemap": "^1.2",
        "npm-asset/select2": "^4.0"
    },
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Big Fish",
            "email": "54217807@qq.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
